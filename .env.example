# Lumiasia Phase 3 Content Variables
# Copy this file to .env.local and fill in the values below to connect to your live CMS.

# Headless CMS Endpoint (e.g., Supabase or Sanity URL)
VITE_CMS_API_URL=https://api.example.com/v1/projects

# Base URL for optimized 3D assets (e.g., AWS CloudFront, Vercel Blob)
VITE_ASSET_BASE_URL=https://assets.example.com/3d/
